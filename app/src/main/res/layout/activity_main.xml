<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg33"
    android:fillViewport="true"
    android:layoutDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/rptbold"
                android:text="مرحباً!"
                android:textColor="@color/black"
                android:textSize="26sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:layout_marginStart="8dp"
                android:src="@drawable/hand" />
        </LinearLayout>

        <!-- البطاقة -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/subTitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="نحن سعداء بتواجدك هنا"
                android:textColor="@color/text"
                android:textSize="16sp" />

            <ImageView
                android:layout_width="220dp"
                android:layout_height="160dp"
                android:layout_gravity="center"
                android:layout_marginBottom="10dp"
                android:src="@drawable/msaferlogo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="15dp"
                android:fontFamily="@font/rptbold"
                android:text="تسجيل الدخول"
                android:textColor="@color/primary"
                android:textSize="26sp"
                android:textStyle="bold" />

            <!-- رقم الهاتف -->
            <EditText
                android:id="@+id/phoneEditText"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/edittext_background"
                android:drawableRight="@drawable/phone"
                android:drawablePadding="12dp"
                android:hint="رقم الهاتف"
                android:inputType="number"
                android:padding="12dp"
                android:textColor="@android:color/black"
                android:textColorHint="#BCBCBC" />

            <TextView
                android:id="@+id/phoneError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="@android:color/holo_red_dark"
                android:textSize="14sp"
                android:visibility="gone" />
            <!-- كلمة المرور -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <EditText
                    android:id="@+id/passwordEditText"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/edittext_background"
                    android:drawableRight="@drawable/pass"
                    android:drawablePadding="12dp"
                    android:gravity="right"
                    android:hint="كلمة المرور"
                    android:inputType="numberPassword"
                    android:maxLength="6"
                    android:padding="12dp"
                    android:textColor="@android:color/black"
                    android:textColorHint="#BCBCBC" />

                <ImageView
                    android:id="@+id/ivToggleNew"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="عرض/إخفاء"
                    android:src="@drawable/baseline_visibility_off_24" />
            </FrameLayout>

            <TextView
                android:id="@+id/passwordError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="@android:color/holo_red_dark"
                android:textSize="14sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/forgotPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:text="نسيت كلمة المرور؟"
                android:textColor="@color/primary2"
                android:textSize="16sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/loginButton"
                style="@style/PrimaryButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginBottom="8dp"
                android:gravity="center"
                android:stateListAnimator="@null"
                android:text="تسجيل الدخول"
                android:textAllCaps="false" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layoutDirection="rtl"
            android:orientation="horizontal">

            <!-- الموقع -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/skipText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="الدخول كزائر"
                    android:textColor="@color/primary2"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/registerText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" ليس لديك حساب؟ "
                    android:textColor="@color/text"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="سجل الآن"
                    android:textColor="@color/primary2"
                    android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_call"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="50dp"
                android:layout_height="60dp"
                android:layout_marginEnd="16dp"
                android:padding="0dp"
                app:cornerRadius="12dp"
                app:icon="@drawable/phone"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="24dp"
                app:iconTint="@color/primary"
                app:strokeColor="#E0E0E0" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_whatsapp_driver"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="50dp"
                android:layout_height="60dp"
                android:padding="0dp"
                app:cornerRadius="12dp"
                app:icon="@drawable/whatsappn"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="24dp"
                app:iconTint="@color/primary"
                app:strokeColor="#E0E0E0" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
