                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/rptbold"
                    android:text="مسافر؟"
                    android:textColor="@color/primary2"
                    android:textSize="20sp"
                    android:textStyle="bold" />

