<!--        app:lottie_loop="true"-->
<!--        app:lottie_rawRes="@raw/typing_animation"-->
<!--        app:lottie_colorFilter="@color/primary"-->
<!--        android:alpha="0.5" />-->

</androidx.constraintlayout.widget.ConstraintLayout>
