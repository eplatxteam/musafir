                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/rptbold"
                                    android:text="ابحث"
                                    android:textColor="@color/black"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                                <TextView
