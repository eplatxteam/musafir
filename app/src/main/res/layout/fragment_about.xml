                            android:layout_height="40dp"
                            android:layout_gravity="top|center_horizontal"
                            android:layout_marginTop="-12dp"
                            app:cardBackgroundColor="#FFFFFF"
                            app:cardCornerRadius="20dp"
                            app:cardElevation="3dp"
                            app:strokeColor="#f2f2f2"
                            app:strokeWidth="1dp">

                            <TextView
