<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray"
    tools:context=".AddTravelerRequests">

    <ScrollView
        android:id="@+id/scrollViewcon"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:scrollbars="none"
        android:textDirection="rtl">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- بطاقة النموذج -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="50dp"
                android:layoutDirection="rtl"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- عنوان النموذج -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="5dp"
                        android:text="نموذج تعبئة طلب لخدمات المسافرين"
                        android:textColor="@color/primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/title_serv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/kaaba_new" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="الخدمة"
                            android:textColor="@color/black"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="15dp"
                            android:text=" *"
                            android:textColor="@android:color/holo_red_dark"
                            android:textSize="22sp" />

                        <View
                            android:layout_width="80dp"
                            android:layout_height="1dp" />

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/shield" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="الضمانة"
                            android:textColor="@color/black"
                            android:textSize="16sp" />


                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">


                        <RadioGroup
                            android:id="@+id/radioRequestType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <RadioButton
                                android:id="@+id/radio1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/custom_radio"
                                android:button="@null"
                                android:checked="true"
                                android:paddingLeft="20dp"
                                android:paddingRight="20dp"
                                android:text="عمرة"
                                android:textColor="@color/radio_text_color"
                                android:textSize="16sp"
                                android:textStyle="bold" />


                            <RadioButton
                                android:id="@+id/radio2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="16dp"
                                android:background="@drawable/custom_radio"
                                android:button="@null"
                                android:paddingLeft="20dp"
                                android:paddingRight="20dp"
                                android:text="حج"
                                android:textColor="@color/radio_text_color"
                                android:textSize="16sp" />

                        </RadioGroup>

                        <View
                            android:layout_width="30dp"
                            android:layout_height="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/downloadDocument"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_button"
                            android:elevation="0dp"
                            android:stateListAnimator="@null"
                            android:text="تحميل الضمان"
                            android:textAllCaps="false"
                            android:textColor="@color/primary2"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            app:backgroundTint="@null"
                            app:icon="@drawable/download"
                            app:iconGravity="textStart"
                            app:iconSize="20dp"
                            app:iconTint="@color/primary2" />

                    </LinearLayout>


                    <LinearLayout
                        android:id="@+id/containerHosting"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="8dp"
                            android:src="@drawable/check_file" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="نوع الضمان"
                            android:textColor="@android:color/black"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" *"
                            android:textColor="@android:color/holo_red_dark"
                            android:textSize="22sp" />
                    </LinearLayout>

                    <RadioGroup
                        android:id="@+id/radioisHosting"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/Guarantee"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:layout_weight="1"
                            android:background="@drawable/custom_radio"
                            android:button="@null"
                            android:checked="true"
                            android:gravity="center"
                            android:paddingVertical="10dp"
                            android:text="ضمانة تجارية"
                            android:textColor="@color/radio_text_color"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <RadioButton
                            android:id="@+id/host"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/custom_radio"
                            android:button="@null"
                            android:gravity="center"
                            android:paddingVertical="10dp"
                            android:text="مستضيف"
                            android:textColor="@color/radio_text_color"
                            android:textSize="16sp" />

                        <!--                            <RadioButton-->
                        <!--                                android:id="@+id/back"-->
                        <!--                                android:layout_width="0dp"-->
                        <!--                                android:layout_height="wrap_content"-->
                        <!--                                android:layout_weight="1"-->
                        <!--                                android:background="@drawable/custom_radio"-->
                        <!--                                android:button="@null"-->
                        <!--                                android:gravity="center"-->
                        <!--                                android:paddingVertical="10dp"-->
                        <!--                                android:text="عودة"-->
                        <!--                                android:textColor="@color/radio_text_color"-->
                        <!--                                android:textSize="16sp" />-->
                    </RadioGroup>

                    <LinearLayout
                        android:id="@+id/FlightContainer"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
