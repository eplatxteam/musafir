<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="10dp"
    android:layoutDirection="rtl"
    android:gravity="center_vertical"
    android:layout_marginBottom="8dp">

    <!-- النصوص -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtRouteName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="اسم المسار"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:textStyle="bold" />

<!--        <TextView-->
<!--            android:id="@+id/txtRouteDescription"-->
<!--            android:layout_width="match_parent"-->
<!--            android:layout_height="wrap_content"-->
<!--            android:text="وصف المسار"-->
<!--            android:textSize="14sp"-->
<!--            android:textColor="#666666" />-->
    </LinearLayout>

    <!-- السويتش -->
    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switchNotificationrout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:thumbTint="@color/switch_text_color"
        android:trackTint="@color/switch_track_color"
        android:backgroundTint="@color/switch_text_color"/>
</LinearLayout>
