<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F6F6"
    android:layoutDirection="rtl">
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/main_toolbar"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:background="@drawable/bg2"
        android:elevation="4dp"
        app:navigationIcon="@drawable/icons8_back_to_1"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
        app:contentInsetStartWithNavigation="0dp"
        android:paddingTop="5dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="5dp">

            <ImageView
                android:id="@+id/toolbar_icon"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:src="@drawable/robot2"
                android:layout_marginEnd="10dp"
                android:scaleType="centerInside"/>

            <TextView
                android:id="@+id/toolbar_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="مساعد مسافر"
                android:textColor="@color/black"
                android:textSize="17sp"/>

        </LinearLayout>

    </androidx.appcompat.widget.Toolbar>

    <LinearLayout
        android:id="@+id/inputContainer"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:background="@drawable/bg_chat_input"
        android:elevation="0dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="3dp">

        <EditText
            android:id="@+id/textmsg"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/bg_white_input"
            android:hint="مراسلة"
            android:paddingRight="20dp"
            android:textColor="#333333"
            android:textColorHint="#BCBCBC"
            android:textSize="13sp" />


        <ImageButton
            android:id="@+id/sendmsg"
            android:layout_width="70dp"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="14dp"
            android:scaleType="centerInside"
            android:src="@drawable/send1"
            app:tint="@color/secondary" />
    </LinearLayout>

    <!-- 3. قائمة الدردشة تأخذ المساحة المتبقية بين التولبار وصندوق الإدخال -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/inputContainer"
        android:layout_below="@id/main_toolbar"
        android:clipToPadding="false"
        android:padding="12dp"
        android:scrollbars="none" />

</RelativeLayout>