                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:fontFamily="@font/rptbold"
                                android:text="1"
                                android:textColor="@color/primary2"
                                android:textSize="16sp" />
                        </com.google.android.material.card.MaterialCardView>
                    </FrameLayout>

                    <FrameLayout
